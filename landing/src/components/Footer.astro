---
const quickLinks = [
  { label: 'Início', href: '#hero' },
  { label: 'Recursos', href: '#recursos' },
  { label: 'Diferenciais', href: '#diferenciais' },
  { label: 'Contato', href: '#contato' },
]

const legalLinks = [
  { label: 'Política de Privacidade', href: '/privacidade' },
  { label: 'Termos de Uso', href: '/termos' },
]
---

<footer class="border-t border-rose-600/30 bg-slate-900">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-8 md:grid-cols-3">
      <div class="space-y-3">
        <a href="/" class="flex items-center gap-2 text-lg font-bold text-white">
          <span aria-hidden="true">🏢</span>
          <span>CondoCombat</span>
        </a>
        <p class="max-w-xs text-sm leading-relaxed text-slate-400">
          Gerenciando o caos do seu condomínio com estilo
        </p>
      </div>

      <div>
        <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-slate-300">Links</h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-slate-400 transition-colors hover:text-rose-400"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-slate-300">Legal</h3>
        <ul class="space-y-2">
          {legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-slate-400 transition-colors hover:text-rose-400"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-10 border-t border-slate-800 pt-6">
      <p class="text-center text-xs text-slate-500">
        &copy; 2026 CondoCombat — Gerenciando o caos do seu condomínio com estilo
      </p>
    </div>
  </div>
</footer>
